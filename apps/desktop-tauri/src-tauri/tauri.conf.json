{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "CodexPet Nest",
  "version": "0.1.12",
  "identifier": "xyz.codexpet.nest",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "FSL-1.1-MIT. Converts to MIT on 2028-05-06. Copyright (c) 2026 Ryan Niu.",
    "category": "DeveloperTool",
    "shortDescription": "CodexPet Nest - Desktop Pet Manager",
    "longDescription": "A Tauri-based desktop companion for managing Codex pets, nests, and widgets.",
    "macOS": {
      "minimumSystemVersion": "14.0"
    },
    "windows": {
      "nsis": null
    }
  }
}
