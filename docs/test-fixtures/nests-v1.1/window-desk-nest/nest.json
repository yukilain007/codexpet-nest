{
  "schemaVersion": "1.1.0",
  "canvas": { "width": 320, "height": 180 },
  "layers": [
    {
      "id": "bg",
      "type": "image",
      "src": "assets/background.png",
      "frame": { "x": 0, "y": 0, "width": 320, "height": 180 }
    }
  ],
  "elements": [
    {
      "id": "day-night-icon",
      "type": "variantImage",
      "metric": "system.time.day_period",
      "frame": { "x": 200, "y": 20, "width": 32, "height": 32 },
      "variants": {
        "day": "assets/sun.png",
        "night": "assets/moon.png"
      },
      "fallback": "assets/sun.png"
    },
    {
      "id": "clock-text",
      "type": "metricText",
      "metric": "system.time.hhmm",
      "frame": { "x": 105, "y": 70, "width": 110, "height": 30 },
      "style": {
        "fontSize": 24,
        "fontWeight": "bold",
        "color": "#333333",
        "alignment": "center"
      }
    },
    {
      "id": "primary-usage-bar",
      "type": "metricGauge",
      "metric": "usage.primary.remaining_ratio",
      "renderer": "linearBar",
      "frame": { "x": 60, "y": 140, "width": 200, "height": 6 },
      "style": {
        "fillColor": "#4CAF50",
        "trackColor": "#00000022",
        "direction": "leftToRight",
        "cornerRadius": 3
      }
    },
    {
      "id": "secondary-usage-bar",
      "type": "metricGauge",
      "metric": "usage.secondary.remaining_ratio",
      "renderer": "linearBar",
      "frame": { "x": 60, "y": 150, "width": 200, "height": 6 },
      "style": {
        "fillColor": "#2196F3",
        "trackColor": "#00000022",
        "direction": "leftToRight",
        "cornerRadius": 3
      }
    }
  ]
}
